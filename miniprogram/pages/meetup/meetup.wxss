/* pages/meetup/meetup.wxss */

.page {
  min-height: 100vh;
  background-color: var(--bg-primary);
  padding-bottom: 120rpx;
}

/* Filter Bar */
.filter-bar {
  display: flex;
  background-color: var(--bg-secondary);
  padding: 16rpx 32rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: 8rpx;
  transition: all 0.3s;
}

.filter-item.active {
  color: var(--primary-color);
  background-color: rgba(201, 168, 108, 0.1);
  font-weight: 600;
}

/* Meetup List */
.meetup-list {
  padding: 24rpx 32rpx;
}

.meetup-card {
  display: flex;
  background-color: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  position: relative;
}

/* Date Badge */
.date-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  background-color: var(--primary-color);
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.date-day {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--bg-primary);
  line-height: 1;
}

.date-month {
  font-size: 22rpx;
  color: var(--bg-primary);
}

/* Meetup Info */
.meetup-info {
  flex: 1;
  min-width: 0;
}

.meetup-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.meetup-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  margin-right: 12rpx;
}

.joined-badge {
  font-size: 22rpx;
  color: #4caf50;
  background-color: rgba(76, 175, 80, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

/* Meta Info */
.meetup-meta {
  margin-bottom: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.meta-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.meta-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* Footer */
.meetup-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.participants {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.participants-count {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.participants-label {
  font-size: 24rpx;
  color: var(--text-muted);
}

.price-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary-color);
}

/* FAB */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(201, 168, 108, 0.3);
}

.fab-icon {
  font-size: 48rpx;
  color: var(--bg-primary);
  font-weight: 300;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 96rpx 32rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
  margin-bottom: 32rpx;
}

/* Loading */
.loading {
  text-align: center;
  padding: 48rpx;
  color: var(--text-secondary);
}