/* pages/humidor/humidor.wxss */

.page {
  min-height: 100vh;
  background-color: var(--bg-primary);
  padding-bottom: 120rpx;
}

/* Login Prompt */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  padding: 32rpx;
}

.login-icon {
  font-size: 128rpx;
  margin-bottom: 32rpx;
}

.login-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.login-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 48rpx;
  text-align: center;
}

/* Stats Section */
.stats-section {
  padding: 32rpx;
}

.stats-card {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background-color: var(--bg-card);
  border-radius: 16rpx;
  padding: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: var(--border-color);
}

/* Toolbar */
.toolbar {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  gap: 16rpx;
}

.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: var(--bg-secondary);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-placeholder {
  color: var(--text-muted);
}

.view-toggle {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-secondary);
  border-radius: 12rpx;
  font-size: 32rpx;
  color: var(--text-secondary);
}

/* List View */
.humidor-list {
  padding: 0 32rpx;
}

.humidor-item {
  display: flex;
  background-color: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.cigar-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #333;
  flex-shrink: 0;
}

.cigar-details {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.cigar-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.cigar-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-right: 12rpx;
}

.cigar-rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.rating-star {
  color: var(--primary-color);
  font-size: 24rpx;
}

.rating-value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.cigar-brand {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.cigar-meta {
  display: flex;
  justify-content: space-between;
  margin-top: auto;
}

.quantity,
.price {
  font-size: 24rpx;
  color: var(--text-muted);
}

.price {
  color: var(--primary-color);
  font-weight: 500;
}

/* Grid View */
.humidor-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx;
  gap: 16rpx;
}

.grid-item {
  width: calc(50% - 8rpx);
  background-color: var(--bg-card);
  border-radius: 16rpx;
  overflow: hidden;
}

.grid-image {
  width: 100%;
  height: 280rpx;
  background-color: #333;
}

.grid-info {
  padding: 16rpx;
}

.grid-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.grid-quantity {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* FAB */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(201, 168, 108, 0.3);
}

.fab-icon {
  font-size: 48rpx;
  color: var(--bg-primary);
  font-weight: 300;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 96rpx 32rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
  margin-bottom: 32rpx;
}

/* Loading */
.loading {
  text-align: center;
  padding: 48rpx;
  color: var(--text-secondary);
}