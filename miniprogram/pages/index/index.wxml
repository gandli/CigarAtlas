<!--pages/index/index.wxml-->
<view class="page">
  <!-- 顶部 Banner -->
  <view class="banner">
    <view class="banner-content">
      <text class="banner-title">探索雪茄世界</text>
      <text class="banner-subtitle">记录品鉴，分享体验，结识同好</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-actions">
    <navigator url="/pages/journal/journal" class="action-item">
      <view class="action-icon">📝</view>
      <text class="action-text">写品鉴</text>
    </navigator>
    <navigator url="/pages/humidor/humidor" class="action-item">
      <view class="action-icon">🗃️</view>
      <text class="action-text">我的雪茄柜</text>
    </navigator>
    <navigator url="/pages/social/social" class="action-item">
      <view class="action-icon">💬</view>
      <text class="action-text">圈子话题</text>
    </navigator>
    <navigator url="/pages/meetup/meetup" class="action-item">
      <view class="action-icon">📅</view>
      <text class="action-text">附近活动</text>
    </navigator>
  </view>

  <!-- 推荐雪茄 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">推荐雪茄</text>
      <navigator url="/pages/cigars/cigars" class="section-more">更多 ></navigator>
    </view>
    <scroll-view scroll-x class="cigar-scroll">
      <view class="cigar-list">
        <view wx:for="{{featuredCigars}}" wx:key="id" class="cigar-card" bindtap="navigateToCigar" data-id="{{item.id}}">
          <image class="cigar-image" src="{{item.image || '/assets/images/cigar-placeholder.png'}}" mode="aspectFill"></image>
          <view class="cigar-info">
            <text class="cigar-name">{{item.name}}</text>
            <text class="cigar-brand">{{item.brand}}</text>
            <view class="cigar-rating">
              <text class="rating-star">★</text>
              <text class="rating-value">{{item.rating}}</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 最近品鉴 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">最近品鉴</text>
      <navigator url="/pages/journal/journal" class="section-more">更多 ></navigator>
    </view>
    <view class="journal-list">
      <view wx:for="{{recentJournals}}" wx:key="id" class="journal-item" bindtap="navigateToJournal" data-id="{{item.id}}">
        <view class="journal-main">
          <text class="journal-title">{{item.title}}</text>
          <view class="journal-meta">
            <text class="journal-author">{{item.author}}</text>
            <text class="journal-date">{{item.date}}</text>
          </view>
        </view>
        <view class="journal-stats">
          <text class="like-count">❤️ {{item.likes}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 即将举行的活动 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">即将举行</text>
      <navigator url="/pages/meetup/meetup" class="section-more">更多 ></navigator>
    </view>
    <view class="meetup-list">
      <view wx:for="{{upcomingMeetups}}" wx:key="id" class="meetup-item" bindtap="navigateToMeetup" data-id="{{item.id}}">
        <view class="meetup-date-box">
          <text class="meetup-date-day">{{item.date.split('-')[2]}}</text>
          <text class="meetup-date-month">{{item.date.split('-')[1]}}月</text>
        </view>
        <view class="meetup-info">
          <text class="meetup-title">{{item.title}}</text>
          <view class="meetup-meta">
            <text class="meetup-location">📍 {{item.location}}</text>
            <text class="meetup-participants">👥 {{item.participants}}人</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 热门话题 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">热门话题</text>
      <navigator url="/pages/social/social" class="section-more">更多 ></navigator>
    </view>
    <view class="topic-list">
      <view wx:for="{{hotTopics}}" wx:key="id" class="topic-item">
        <text class="topic-index">{{index + 1}}</text>
        <view class="topic-content">
          <text class="topic-title">{{item.title}}</text>
          <view class="topic-stats">
            <text class="topic-replies">{{item.replies}}回复</text>
            <text class="topic-views">{{item.views}}浏览</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>
</view>