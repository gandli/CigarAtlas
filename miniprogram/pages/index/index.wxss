/* pages/index/index.wxss */

.page {
  min-height: 100vh;
  background-color: var(--bg-primary);
  padding-bottom: 32rpx;
}

/* Banner */
.banner {
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
  padding: 48rpx 32rpx;
  position: relative;
  overflow: hidden;
}

.banner::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(201, 168, 108, 0.3) 0%, transparent 70%);
  border-radius: 50%;
}

.banner-content {
  position: relative;
  z-index: 1;
}

.banner-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary-color);
  margin-bottom: 16rpx;
}

.banner-subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* Quick Actions */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 16rpx;
  background-color: var(--bg-secondary);
  margin-bottom: 24rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* Section */
.section {
  margin-bottom: 32rpx;
  padding: 0 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-more {
  font-size: 26rpx;
  color: var(--primary-color);
}

/* Cigar Scroll */
.cigar-scroll {
  white-space: nowrap;
  margin: 0 -32rpx;
  padding: 0 32rpx;
}

.cigar-list {
  display: inline-flex;
  gap: 24rpx;
}

.cigar-card {
  width: 240rpx;
  background-color: var(--bg-card);
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.cigar-image {
  width: 100%;
  height: 200rpx;
  background-color: #333;
}

.cigar-info {
  padding: 16rpx;
}

.cigar-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cigar-brand {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.cigar-rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.rating-star {
  color: var(--primary-color);
  font-size: 24rpx;
}

.rating-value {
  font-size: 24rpx;
  color: var(--text-primary);
}

/* Journal List */
.journal-list {
  background-color: var(--bg-secondary);
  border-radius: 16rpx;
  overflow: hidden;
}

.journal-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.journal-item:last-child {
  border-bottom: none;
}

.journal-main {
  flex: 1;
}

.journal-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.journal-meta {
  display: flex;
  gap: 16rpx;
}

.journal-author,
.journal-date {
  font-size: 24rpx;
  color: var(--text-muted);
}

.journal-stats {
  flex-shrink: 0;
}

.like-count {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* Meetup List */
.meetup-list {
  background-color: var(--bg-secondary);
  border-radius: 16rpx;
  overflow: hidden;
}

.meetup-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.meetup-item:last-child {
  border-bottom: none;
}

.meetup-date-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  background-color: var(--primary-color);
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.meetup-date-day {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--bg-primary);
}

.meetup-date-month {
  font-size: 20rpx;
  color: var(--bg-primary);
}

.meetup-info {
  flex: 1;
}

.meetup-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.meetup-meta {
  display: flex;
  gap: 16rpx;
}

.meetup-location,
.meetup-participants {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* Topic List */
.topic-list {
  background-color: var(--bg-secondary);
  border-radius: 16rpx;
  overflow: hidden;
}

.topic-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.topic-item:last-child {
  border-bottom: none;
}

.topic-index {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--primary-color);
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--bg-primary);
  margin-right: 16rpx;
  flex-shrink: 0;
}

.topic-content {
  flex: 1;
}

.topic-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.topic-stats {
  display: flex;
  gap: 16rpx;
}

.topic-replies,
.topic-views {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* Loading */
.loading {
  text-align: center;
  padding: 48rpx;
  color: var(--text-secondary);
}