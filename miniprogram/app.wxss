/* app.wxss - Global Styles */

/* Color Variables (using CSS custom properties for modern approach) */
page {
  --primary-color: #c9a86c;
  --primary-dark: #a88a4e;
  --primary-light: #e8d5a8;
  --bg-primary: #0d0d0d;
  --bg-secondary: #1a1a1a;
  --bg-card: #242424;
  --text-primary: #ffffff;
  --text-secondary: #888888;
  --text-muted: #666666;
  --border-color: #333333;
  --success-color: #4caf50;
  --warning-color: #ff9800;
  --error-color: #f44336;

  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* Container */
.container {
  padding: 32rpx;
  box-sizing: border-box;
}

/* Cards */
.card {
  background-color: var(--bg-card);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary-color);
  margin-bottom: 16rpx;
}

/* Buttons */
.btn-primary {
  background-color: var(--primary-color);
  color: var(--bg-primary);
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-weight: 600;
  text-align: center;
}

.btn-secondary {
  background-color: transparent;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  border-radius: 12rpx;
  padding: 22rpx 46rpx;
  font-weight: 600;
  text-align: center;
}

/* Flex utilities */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

/* Text utilities */
.text-primary {
  color: var(--primary-color);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-muted {
  color: var(--text-muted);
}

/* Divider */
.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: 24rpx 0;
}

/* Loading */
.loading {
  text-align: center;
  padding: 48rpx;
  color: var(--text-secondary);
}

/* Empty state */
.empty-state {
  text-align: center;
  padding: 96rpx 32rpx;
  color: var(--text-muted);
}

.empty-state-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-state-text {
  font-size: 28rpx;
}