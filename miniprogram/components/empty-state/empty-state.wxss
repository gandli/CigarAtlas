/* components/empty-state/empty-state.wxss */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 96rpx 32rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
  margin-bottom: 32rpx;
}

.btn-primary {
  background-color: var(--primary-color);
  color: var(--bg-primary);
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-weight: 600;
  text-align: center;
  border: none;
}