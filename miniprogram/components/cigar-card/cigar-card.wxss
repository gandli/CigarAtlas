/* components/cigar-card/cigar-card.wxss */

.cigar-card {
  background-color: var(--bg-card);
  border-radius: 16rpx;
  overflow: hidden;
}

.cigar-image {
  width: 100%;
  height: 280rpx;
  background-color: #333;
}

.cigar-info {
  padding: 20rpx;
}

.cigar-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cigar-brand {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.cigar-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.star {
  color: var(--primary-color);
  font-size: 26rpx;
}

.value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.action-icon {
  font-size: 24rpx;
  color: var(--primary-color);
}