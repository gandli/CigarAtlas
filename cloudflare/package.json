{
  "name": "cigaratlas-api",
  "version": "1.0.0",
  "description": "CigarAtlas API - Cloudflare Workers backend",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --config wrangler.production.toml",
    "db:create": "wrangler d1 create cigaratlas-db",
    "db:create:prod": "wrangler d1 create cigaratlas-db-prod",
    "db:migrate": "wrangler d1 migrations apply cigaratlas-db",
    "db:migrate:local": "wrangler d1 migrations apply cigaratlas-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply cigaratlas-db-prod --config wrangler.production.toml",
    "db:query": "wrangler d1 execute cigaratlas-db --file",
    "db:query:local": "wrangler d1 execute cigaratlas-db --local --file",
    "tail": "wrangler tail",
    "test": "vitest"
  },
  "keywords": ["cigaratlas", "cloudflare", "workers", "api"],
  "author": "CigarAtlas Team",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.75.0"
  },
  "dependencies": {
    "@tsndr/cloudflare-worker-jwt": "^3.2.1",
    "hono": "^4.12.8",
    "zod": "^3.25.76"
  }
}